<?xml version="1.0" encoding="utf-8"?>
<SisMasterConfig>

  <!-- Banco de dados.
       CaminhoDb: relativo ao executável ou absoluto. Criado automaticamente na primeira execução.
       IntervaloColetaMinutos: frequência de gravação das temperaturas.
       ColetarSemConexao: true = continua gravando (clp_ok=0) se o CLP perder comunicação. -->
  <BancoDados>
    <CaminhoDb>dados\sensores.db</CaminhoDb>
    <IntervaloColetaMinutos>10</IntervaloColetaMinutos>
    <ColetarSemConexao>true</ColetarSemConexao>
    <RetencaoMeses>12</RetencaoMeses>
  </BancoDados>

  <!-- Configurações de relatórios e PDF.
       PastaExportacao: relativo ao executável ou absoluto.
       FooterTexto: {DATA} e {HORA} são substituídos automaticamente na geração.
       PeriodoPadraoAtrasoDias: janela de datas padrão ao abrir a tela de relatórios. -->
  <Relatorios>
    <NomeCliente>Boa Carne</NomeCliente>
    <NomeInstalacao>Frigorifico Boa Carne - Colider/MT</NomeInstalacao>
    <FooterTexto>SisMaster Supervisório de Refrigeração | Gerado em {DATA} | {HORA}</FooterTexto>
    <PastaExportacao>relatorios</PastaExportacao>
    <PeriodoPadraoAtrasoDias>7</PeriodoPadraoAtrasoDias>
  </Relatorios>

  <!-- Nomes dos sensores exibidos na tela de relatórios e no PDF.
       Altere o atributo "nome" para customizar o rótulo.
       O "id" é fixo e corresponde ao índice do array Ambientes() no código. -->
